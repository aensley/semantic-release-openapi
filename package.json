{
  "name": "semantic-release-openapi",
  "version": "2.3.5",
  "description": "A Semantic Release plugin to update versions in OpenAPI / Swagger specification files",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aensley/semantic-release-openapi.git"
  },
  "keywords": [
    "api",
    "asyncapi",
    "json",
    "oas",
    "openapi",
    "plugin",
    "publish",
    "release",
    "rest",
    "semantic-release",
    "swagger",
    "swagger-api",
    "update",
    "version",
    "yaml",
    "yml"
  ],
  "author": {
    "name": "Andrew Ensley",
    "email": "aensley@users.noreply.github.com",
    "url": "https://andrewensley.com"
  },
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aensley/semantic-release-openapi/issues/new?template=bug-report.yml"
  },
  "funding": [
    "https://github.com/sponsors/aensley",
    "https://paypal.me/AndrewEnsley"
  ],
  "homepage": "https://github.com/aensley/semantic-release-openapi#readme",
  "exports": "./dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "dist/**/*",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "npm run lint:code && npm run lint:lockfile && npm run lint:publint",
    "lint:code": "prettier --check .",
    "lint:code:fix": "prettier --write .",
    "lint:lockfile": "lockfile-lint >/dev/null",
    "lint:engines": "npx ls-engines --mode virtual",
    "lint:publint": "publint --strict",
    "packito": "packito --no-publish",
    "pre-commit-msg": "echo Running pre-commit checks...",
    "pre-publish": "npm run build && npm run packito && cp README.md dist/ && cp LICENSE dist/",
    "test": "npm run lint && NODE_OPTIONS=--experimental-vm-modules jest --coverage --verbose",
    "test:unit": "JEST_GROUP=unit NODE_OPTIONS=--experimental-vm-modules node test/scripts/jest-group.mjs --verbose",
    "test:integration": "JEST_GROUP=integration NODE_OPTIONS=--experimental-vm-modules node test/scripts/jest-group.mjs --verbose",
    "update": "npx npm-check-updates -u && npm update"
  },
  "pre-commit": {
    "run": [
      "pre-commit-msg",
      "test"
    ],
    "silent": true,
    "colors": true
  },
  "engines": {
    "node": ">= 22.14"
  },
  "platform": "node",
  "dependencies": {
    "@semantic-release/error": "^4.0.0",
    "fdir": "^6.5.0",
    "jsonfile": "^6.2.1"
  },
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsonfile": "^6.1.4",
    "@types/node": "^25.9.1",
    "@types/picomatch": "^4.0.3",
    "@types/semantic-release__error": "^3.0.3",
    "@types/signale": "^1.4.7",
    "czg": "^1.13.1",
    "jest": "^30.4.2",
    "jest-runner-groups": "^2.2.0",
    "jiti": "^2.7.0",
    "lockfile-lint": "^5.0.0",
    "packito": "^0.5.0",
    "pre-commit": "^2.0.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "semantic-release": ">=20.0.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/npm",
        {
          "pkgRoot": "dist",
          "npmPublish": true,
          "provenance": true
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json"
          ]
        }
      ]
    ]
  },
  "prettier": {
    "tabWidth": 2,
    "printWidth": 120,
    "useTabs": false,
    "endOfLine": "lf",
    "trailingComma": "none",
    "semi": false,
    "singleQuote": true,
    "arrowParens": "always",
    "bracketSameLine": true,
    "bracketSpacing": true,
    "embeddedLanguageFormatting": "auto",
    "htmlWhitespaceSensitivity": "css",
    "insertPragma": false,
    "jsxSingleQuote": false,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "requirePragma": false,
    "vueIndentScriptAndStyle": false
  },
  "jest": {
    "runner": "jest-runner-groups",
    "clearMocks": true,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json",
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(@semantic-release/error|fdir)/)"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "lockfile-lint": {
    "path": "package-lock.json",
    "type": "npm",
    "validate-https": true,
    "validate-host": true,
    "validate-package-names": false,
    "validate-scheme": true,
    "validate-integrity": true,
    "allowed-hosts": [
      "npm"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "type": "conventional",
      "useEmoji": true
    }
  }
}
