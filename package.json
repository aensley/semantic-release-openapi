{
  "name": "semantic-release-openapi",
  "version": "2.0.1",
  "description": "A Semantic Release plugin to update versions in OpenAPI / Swagger specification files",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aensley/semantic-release-openapi.git"
  },
  "keywords": [
    "semantic-release",
    "plugin",
    "openapi",
    "version",
    "swagger",
    "asyncapi"
  ],
  "author": {
    "name": "Andrew Ensley",
    "email": "aensley@users.noreply.github.com",
    "url": "https://andrewensley.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aensley/semantic-release-openapi/issues/new?template=bug-report.yml"
  },
  "funding": [
    "https://github.com/sponsors/aensley",
    "https://paypal.me/AndrewEnsley"
  ],
  "homepage": "https://github.com/aensley/semantic-release-openapi#readme",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "dist/**/*",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "ts-standard && prettier --check .",
    "lint:fix": "prettier --write .",
    "packito": "packito --no-publish",
    "pre-commit-msg": "echo Running pre-commit checks...",
    "pre-publish": "npm run build && npm run packito && cp README.md dist/ && cp LICENSE dist/",
    "setup": "npm install && npm run prepare-hook",
    "test": "npm run lint && jest --coverage --verbose",
    "update": "npx npm-check-updates -u && npm update"
  },
  "pre-commit": {
    "run": [
      "pre-commit-msg",
      "test"
    ],
    "silent": true,
    "colors": true
  },
  "engines": {
    "node": ">=16"
  },
  "platform": "node",
  "dependencies": {
    "@semantic-release/error": "^4.0.0",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "replace-in-file": "^8.4.0",
    "semantic-release": "^25.0.3"
  },
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.1",
    "@types/semantic-release": "^21.1.0",
    "@types/semantic-release__error": "^3.0.3",
    "@types/signale": "^1.4.7",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "jest": "^30.4.0",
    "packito": "^0.5.0",
    "pre-commit": "^2.0.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-standard": "^12.0.2",
    "typescript": "^6.0.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/npm",
        {
          "pkgRoot": "dist",
          "npmPublish": true
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json"
          ]
        }
      ]
    ]
  },
  "eslintConfig": {
    "extends": "standard-with-typescript",
    "parserOptions": {
      "project": "./tsconfig.json"
    }
  },
  "ts-standard": {
    "globals": [],
    "ignore": [
      "/test/**/*.ts"
    ]
  },
  "prettier": {
    "tabWidth": 2,
    "printWidth": 120,
    "useTabs": false,
    "endOfLine": "lf",
    "trailingComma": "none",
    "semi": false,
    "singleQuote": true,
    "arrowParens": "always",
    "bracketSameLine": true,
    "bracketSpacing": true,
    "embeddedLanguageFormatting": "auto",
    "htmlWhitespaceSensitivity": "css",
    "insertPragma": false,
    "jsxSingleQuote": false,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "requirePragma": false,
    "vueIndentScriptAndStyle": false
  },
  "jest": {
    "clearMocks": true,
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(@semantic-release/error|glob|replace-in-file)/)"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
